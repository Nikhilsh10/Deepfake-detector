# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
venv/
.env

# ── Data (keep dirs, ignore contents) ──────────────────────────────────────
data/uploads/*
data/processed/*
data/*.db
!data/uploads/.gitkeep
!data/processed/.gitkeep

# ── Models (large binary files) ────────────────────────────────────────────
models/*.pth
models/*.pt
models/*.onnx

# ── Node / Frontend ────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env

# ── IDE / OS ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
